    "package-directory": "^8.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "shiki": "^3.22.0",
    "svelte": "5.50.1",
    "svelte-check": "^4.3.6",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
